{
  "name": "Min Tab",
  "version": "2.4",
  "manifest_version": 3,
  "description": "A minimalist new tab page with multi-engine search, smart suggestions from history, keyboard navigation, and light/dark theme support.",
  "browser_specific_settings": {
    "gecko": {
      "id": "min-tab@extension.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "chrome_url_overrides": {
    "newtab": "new_tab.html"
  },
  "permissions": [
    "history",
    "topSites"
  ],
  "icons": {
    "128": "./assets/images/icon128.png"
  }
}